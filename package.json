{
  "name": "license-check",
  "version": "0.1.0",
  "description": "Scan an npm project's dependency tree, identify each dependency's license, and flag policy violations and missing licenses. Offline by default. SPDX-aware.",
  "keywords": [
    "license",
    "spdx",
    "compliance",
    "dependencies",
    "cli",
    "github-actions",
    "npm",
    "developer-tools"
  ],
  "homepage": "https://github.com/anthill24/license-check#readme",
  "bugs": {
    "url": "https://github.com/anthill24/license-check/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anthill24/license-check.git"
  },
  "license": "MIT",
  "author": "anthill24",
  "type": "module",
  "bin": {
    "license-check": "dist/cli.js"
  },
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^8.57.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
